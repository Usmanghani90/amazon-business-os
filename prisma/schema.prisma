// ============================================================================
// Amazon Business OS — Prisma Schema
// Enterprise operating system for a multi-partner Amazon FBA business.
// PostgreSQL · normalized · architecture-ready for SP-API + AI features.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection used for migrations. On Neon this is the
  // URL without "-pooler". Locally it can equal DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  PARTNER
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum PaymentMethod {
  BANK_TRANSFER
  WISE
  PAYONEER
  MERCURY
  CREDIT_CARD
  DEBIT_CARD
  CASH
  PAYPAL
  CHEQUE
  OTHER
}

enum BankAccountType {
  BUSINESS_BANK
  WISE
  PAYONEER
  MERCURY
  CREDIT_CARD
  CASH
  OTHER
}

enum BankTxnType {
  MONEY_IN
  MONEY_OUT
  TRANSFER_IN
  TRANSFER_OUT
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  RECONCILED
}

enum ProductStatus {
  ACTIVE
  LAUNCHING
  RESEARCH
  INACTIVE
  DISCONTINUED
  OUT_OF_STOCK
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  IN_PRODUCTION
  QUALITY_CHECK
  SHIPPED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum AdType {
  SPONSORED_PRODUCTS
  SPONSORED_BRANDS
  SPONSORED_DISPLAY
  DSP
}

enum LedgerEntryType {
  INVESTMENT
  EXPENSE_PAID
  WITHDRAWAL
  PROFIT_SHARE
  SETTLEMENT
  ADJUSTMENT
}

enum NotificationType {
  LOW_INVENTORY
  INVENTORY_STOCKOUT
  SUPPLIER_PAYMENT_DUE
  AMAZON_PAYOUT_RECEIVED
  LARGE_EXPENSE
  PARTNER_INVESTMENT
  PARTNER_WITHDRAWAL
  PURCHASE_ORDER_ARRIVAL
  SYSTEM
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum IntegrationProvider {
  AMAZON_SP_API
  AMAZON_ADS_API
  HELIUM10
  KEEPA
  WISE
  PAYONEER
  GOOGLE_SHEETS
  SLACK
  GMAIL
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum AiInsightType {
  PROFIT_RECOMMENDATION
  INVENTORY_FORECAST
  PPC_OPTIMIZATION
  CASH_FLOW_FORECAST
  EXPENSE_ANOMALY
  EXECUTIVE_SUMMARY
  ASSISTANT_ANSWER
}

// ============================================================================
// ORGANIZATION & ACCESS
// ============================================================================

model Company {
  id             String   @id @default(cuid())
  name           String
  legalName      String?
  logoUrl        String?
  baseCurrency   String   @default("USD")
  fiscalYearStart Int     @default(1) // month 1-12
  address        String?
  country        String?
  taxId          String?
  timezone       String   @default("UTC")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String   @unique
  name      String
  avatarUrl String?
  role      UserRole @default(VIEWER)
  active    Boolean  @default(true)
  partner   Partner? @relation(fields: [partnerId], references: [id])
  partnerId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  activityLogs  ActivityLog[]
  reports       Report[]

  @@index([role])
}

model Partner {
  id            String    @id @default(cuid())
  name          String
  email         String?   @unique
  phone         String?
  avatarUrl     String?
  equityPct     Decimal   @default(0) @db.Decimal(6, 3) // ownership %
  joinedDate    DateTime  @default(now())
  active        Boolean   @default(true)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?
  investments   Investment[]
  expensesPaid  Expense[]
  withdrawals   Withdrawal[]
  ledgerEntries PartnerLedgerEntry[]

  @@index([active])
}

// ============================================================================
// SETTINGS / REFERENCE DATA (configurable)
// ============================================================================

model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // ISO 4217, e.g. USD
  name         String
  symbol       String
  exchangeRate Decimal  @default(1) @db.Decimal(14, 6) // to base currency
  isBase       Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Marketplace {
  id          String   @id @default(cuid())
  code        String   @unique // US, UK, DE, CA...
  name        String
  countryCode String
  currency    String   @default("USD")
  domain      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products     Product[]
  expenses     Expense[]
  payouts      AmazonPayout[]
  sales        Sale[]
  adMetrics    AdMetric[]

  @@index([active])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  group     String    @default("Operating") // COGS / Operating / Marketing / Admin
  color     String?
  isCogs    Boolean   @default(false)
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  expenses  Expense[]

  @@index([group])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// BANKING
// ============================================================================

model BankAccount {
  id             String          @id @default(cuid())
  name           String
  type           BankAccountType
  currency       String          @default("USD")
  provider       String?
  accountNumber  String?
  openingBalance Decimal         @default(0) @db.Decimal(16, 2)
  active         Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  transactions   BankTransaction[]
  investments    Investment[]
  expenses       Expense[]
  withdrawals    Withdrawal[]
  payouts        AmazonPayout[]
  poPayments     POPayment[]

  @@index([type])
}

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  bankAccountId String
  date          DateTime
  type          BankTxnType
  amount        Decimal     @db.Decimal(16, 2)
  balanceAfter  Decimal?    @db.Decimal(16, 2)
  description   String
  category      String?
  refType       String? // Investment | Expense | Withdrawal | Payout | POPayment | Transfer
  refId         String?
  createdAt     DateTime    @default(now())

  @@index([bankAccountId, date])
  @@index([refType, refId])
}

// ============================================================================
// PARTNER ACCOUNTING — CAPITAL FLOWS
// ============================================================================

model Investment {
  id              String        @id @default(cuid())
  date            DateTime
  partner         Partner       @relation(fields: [partnerId], references: [id])
  partnerId       String
  amount          Decimal       @db.Decimal(16, 2)
  currency        String        @default("USD")
  amountBase      Decimal       @db.Decimal(16, 2) // converted to base currency
  paymentMethod   PaymentMethod @default(BANK_TRANSFER)
  bankAccount     BankAccount?  @relation(fields: [bankAccountId], references: [id])
  bankAccountId   String?
  referenceNumber String?
  notes           String?
  receiptUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([partnerId, date])
  @@index([date])
}

model Withdrawal {
  id            String       @id @default(cuid())
  date          DateTime
  partner       Partner      @relation(fields: [partnerId], references: [id])
  partnerId     String
  amount        Decimal      @db.Decimal(16, 2)
  currency      String       @default("USD")
  amountBase    Decimal      @db.Decimal(16, 2)
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  bankAccountId String?
  reason        String?
  notes         String?
  receiptUrl    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([partnerId, date])
  @@index([date])
}

model PartnerLedgerEntry {
  id        String          @id @default(cuid())
  partner   Partner         @relation(fields: [partnerId], references: [id])
  partnerId String
  date      DateTime
  type      LedgerEntryType
  amount    Decimal         @db.Decimal(16, 2) // signed: + increases equity, - decreases
  balance   Decimal         @db.Decimal(16, 2) // running balance
  refType   String?
  refId     String?
  notes     String?
  createdAt DateTime        @default(now())

  @@index([partnerId, date])
}

// ============================================================================
// EXPENSES
// ============================================================================

model Expense {
  id            String          @id @default(cuid())
  date          DateTime
  partnerPaid   Partner?        @relation(fields: [partnerPaidId], references: [id])
  partnerPaidId String?
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  amount        Decimal         @db.Decimal(16, 2)
  currency      String          @default("USD")
  amountBase    Decimal         @db.Decimal(16, 2)
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId    String?
  bankAccount   BankAccount?    @relation(fields: [bankAccountId], references: [id])
  bankAccountId String?
  paymentMethod PaymentMethod   @default(BANK_TRANSFER)
  invoiceNumber String?
  marketplace   Marketplace?    @relation(fields: [marketplaceId], references: [id])
  marketplaceId String?
  product       Product?        @relation(fields: [productId], references: [id])
  productId     String?
  notes         String?
  receiptUrl    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date])
  @@index([categoryId, date])
  @@index([partnerPaidId])
  @@index([productId])
}

// ============================================================================
// AMAZON PAYOUTS / SETTLEMENTS
// ============================================================================

model AmazonPayout {
  id            String       @id @default(cuid())
  marketplace   Marketplace  @relation(fields: [marketplaceId], references: [id])
  marketplaceId String
  settlementId  String?      @unique
  startDate     DateTime
  endDate       DateTime
  depositDate   DateTime?
  grossSales    Decimal      @default(0) @db.Decimal(16, 2)
  amazonFees    Decimal      @default(0) @db.Decimal(16, 2)
  refunds       Decimal      @default(0) @db.Decimal(16, 2)
  reserve       Decimal      @default(0) @db.Decimal(16, 2)
  amount        Decimal      @db.Decimal(16, 2) // net settlement amount
  bankReceived  Decimal?     @db.Decimal(16, 2)
  status        PayoutStatus @default(PENDING)
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  bankAccountId String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([depositDate])
  @@index([marketplaceId, endDate])
}

// ============================================================================
// SUPPLIERS & PURCHASE ORDERS
// ============================================================================

model Supplier {
  id                String   @id @default(cuid())
  companyName       String
  country           String?
  contactPerson     String?
  phone             String?
  email             String?
  website           String?
  leadTimeDays      Int?
  paymentTerms      String? // e.g. "30% deposit / 70% before shipping"
  notes             String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products        Product[]
  purchaseOrders  PurchaseOrder[]
  expenses        Expense[]
  documents       Document[]

  @@index([active])
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  poNumber         String              @unique
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  supplierId       String
  status           PurchaseOrderStatus @default(DRAFT)
  orderDate        DateTime            @default(now())
  expectedDelivery DateTime?
  shippingCost     Decimal             @default(0) @db.Decimal(16, 2)
  inspectionCost   Decimal             @default(0) @db.Decimal(16, 2)
  packagingCost    Decimal             @default(0) @db.Decimal(16, 2)
  freightCost      Decimal             @default(0) @db.Decimal(16, 2)
  currency         String              @default("USD")
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  items    PurchaseOrderItem[]
  payments POPayment[]

  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  quantity        Int
  unitCost        Decimal       @db.Decimal(14, 4)
  receivedQty     Int           @default(0)

  @@index([purchaseOrderId])
  @@index([productId])
}

model POPayment {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  date            DateTime
  amount          Decimal       @db.Decimal(16, 2)
  bankAccount     BankAccount?  @relation(fields: [bankAccountId], references: [id])
  bankAccountId   String?
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
}

// ============================================================================
// PRODUCTS · INVENTORY · ECONOMICS
// ============================================================================

model Product {
  id            String        @id @default(cuid())
  name          String
  sku           String        @unique
  asin          String?
  fnsku         String?
  marketplace   Marketplace?  @relation(fields: [marketplaceId], references: [id])
  marketplaceId String?
  brand         String?
  category      String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  supplierId    String?
  launchDate    DateTime?
  status        ProductStatus @default(ACTIVE)
  costPrice     Decimal       @default(0) @db.Decimal(14, 4)
  sellingPrice  Decimal       @default(0) @db.Decimal(14, 2)
  weightKg      Decimal?      @db.Decimal(10, 3)
  lengthCm      Decimal?      @db.Decimal(10, 2)
  widthCm       Decimal?      @db.Decimal(10, 2)
  heightCm      Decimal?      @db.Decimal(10, 2)
  images        String[]      @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  inventory     Inventory?
  economics     ProductEconomics?
  sales         Sale[]
  adMetrics     AdMetric[]
  expenses      Expense[]
  poItems       PurchaseOrderItem[]
  snapshots     InventorySnapshot[]

  @@index([status])
  @@index([asin])
}

/// Unit economics assumptions used to compute CM1/CM2/CM3 and break-even.
model ProductEconomics {
  id                String   @id @default(cuid())
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String   @unique
  referralFeePct    Decimal  @default(15) @db.Decimal(6, 3)
  fbaFee            Decimal  @default(0) @db.Decimal(14, 2)
  storageFeePerUnit Decimal  @default(0) @db.Decimal(14, 4)
  freightPerUnit    Decimal  @default(0) @db.Decimal(14, 4)
  inspectionPerUnit Decimal  @default(0) @db.Decimal(14, 4)
  packagingPerUnit  Decimal  @default(0) @db.Decimal(14, 4)
  miscPerUnit       Decimal  @default(0) @db.Decimal(14, 4)
  updatedAt         DateTime @updatedAt
}

/// Current inventory state per product (latest snapshot).
model Inventory {
  id            String   @id @default(cuid())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String   @unique
  fulfillable   Int      @default(0)
  inbound       Int      @default(0)
  receiving     Int      @default(0)
  reserved      Int      @default(0)
  unfulfillable Int      @default(0)
  dailyVelocity Decimal  @default(0) @db.Decimal(10, 2)
  weeklyVelocity Decimal @default(0) @db.Decimal(10, 2)
  monthlyVelocity Decimal @default(0) @db.Decimal(10, 2)
  reorderPoint  Int      @default(0)
  restockQty    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

/// Historical inventory readings for trend/forecast charts.
model InventorySnapshot {
  id          String   @id @default(cuid())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  date        DateTime
  fulfillable Int      @default(0)
  inbound     Int      @default(0)
  reserved    Int      @default(0)
  totalValue  Decimal  @default(0) @db.Decimal(16, 2)
  createdAt   DateTime @default(now())

  @@unique([productId, date])
  @@index([date])
}

// ============================================================================
// SALES & ADVERTISING (daily granularity)
// ============================================================================

model Sale {
  id            String      @id @default(cuid())
  date          DateTime
  product       Product     @relation(fields: [productId], references: [id])
  productId     String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  marketplaceId String
  units         Int         @default(0)
  orders        Int         @default(0)
  revenue       Decimal     @default(0) @db.Decimal(16, 2)
  sessions      Int         @default(0)
  pageViews     Int         @default(0)
  buyBoxPct     Decimal     @default(0) @db.Decimal(5, 2)
  refundUnits   Int         @default(0)
  refundAmount  Decimal     @default(0) @db.Decimal(16, 2)
  returnUnits   Int         @default(0)
  promoCost     Decimal     @default(0) @db.Decimal(16, 2)
  couponCost    Decimal     @default(0) @db.Decimal(16, 2)
  createdAt     DateTime    @default(now())

  @@unique([productId, marketplaceId, date])
  @@index([date])
  @@index([marketplaceId, date])
}

model AdMetric {
  id            String      @id @default(cuid())
  date          DateTime
  product       Product?    @relation(fields: [productId], references: [id])
  productId     String?
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  marketplaceId String
  adType        AdType      @default(SPONSORED_PRODUCTS)
  campaignName  String?
  placement     String?
  keyword       String?
  matchType     String?
  impressions   Int         @default(0)
  clicks        Int         @default(0)
  spend         Decimal     @default(0) @db.Decimal(16, 2)
  adSales       Decimal     @default(0) @db.Decimal(16, 2)
  adOrders      Int         @default(0)
  adUnits       Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([date])
  @@index([marketplaceId, date])
  @@index([productId, date])
  @@index([campaignName])
}

// ============================================================================
// DOCUMENTS · NOTIFICATIONS · REPORTS · AUDIT
// ============================================================================

model Document {
  id         String    @id @default(cuid())
  name       String
  url        String
  mimeType   String?
  sizeBytes  Int?
  entityType String? // Supplier | PurchaseOrder | Product | Expense ...
  entityId   String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
}

model Notification {
  id        String               @id @default(cuid())
  type      NotificationType
  severity  NotificationSeverity @default(INFO)
  title     String
  message   String
  read      Boolean              @default(false)
  entityType String?
  entityId  String?
  user      User?                @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime             @default(now())

  @@index([read])
  @@index([userId, createdAt])
}

model Report {
  id          String   @id @default(cuid())
  type        String // PARTNER_STATEMENT | INCOME_STATEMENT | ...
  title       String
  params      Json?
  fileUrl     String?
  format      String?  // PDF | XLSX | CSV
  generatedBy User?    @relation(fields: [userId], references: [id])
  userId      String?
  createdAt   DateTime @default(now())

  @@index([type])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================================
// INTEGRATIONS & AI (architecture-ready)
// ============================================================================

model Integration {
  id           String              @id @default(cuid())
  provider     IntegrationProvider @unique
  status       IntegrationStatus   @default(DISCONNECTED)
  config       Json?
  credentials  Json? // store encrypted at app layer
  lastSyncedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model AiInsight {
  id         String        @id @default(cuid())
  type       AiInsightType
  title      String
  content    Json
  entityType String?
  entityId   String?
  score      Decimal?      @db.Decimal(6, 3)
  dismissed  Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([type])
  @@index([entityType, entityId])
}
